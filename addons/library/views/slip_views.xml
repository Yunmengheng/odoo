<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Slip Form View -->
    <record id="view_library_slip_form" model="ir.ui.view">
        <field name="name">library.slip.form</field>
        <field name="model">library.slip</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_return_book" type="object" string="Return Book" class="btn-primary" invisible="state == 'returned'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <field name="student_id"/>
                        <field name="book_id"/>
                        <field name="borrowed_date"/>
                        <field name="return_date"/>
                        <field name="actual_return_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Slip Tree View -->
    <record id="view_library_slip_tree" model="ir.ui.view">
        <field name="name">library.slip.tree</field>
        <field name="model">library.slip</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="student_id"/>
                <field name="book_id"/>
                <field name="borrowed_date"/>
                <field name="return_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Slip Action -->
    <record id="action_library_slip" model="ir.actions.act_window">
        <field name="name">All Slips</field>
        <field name="res_model">library.slip</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
