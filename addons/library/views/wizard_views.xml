<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Book Wizard View -->
    <record id="view_library_book_wizard_form" model="ir.ui.view">
        <field name="name">library.book.wizard.form</field>
        <field name="model">library.book.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name"/>
                    <field name="author"/>
                    <field name="isbn"/>
                    <field name="description"/>
                </group>
                <footer>
                    <button name="action_create_book" string="Create Book" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Book Wizard Action -->
    <record id="action_library_book_wizard" model="ir.actions.act_window">
        <field name="name">Add New Book</field>
        <field name="res_model">library.book.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Student Wizard View -->
    <record id="view_library_student_wizard_form" model="ir.ui.view">
        <field name="name">library.student.wizard.form</field>
        <field name="model">library.student.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name"/>
                    <field name="student_id"/>
                    <field name="email"/>
                    <field name="phone"/>
                </group>
                <footer>
                    <button name="action_create_student" string="Create Student" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Student Wizard Action -->
    <record id="action_library_student_wizard" model="ir.actions.act_window">
        <field name="name">Add New Student</field>
        <field name="res_model">library.student.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
